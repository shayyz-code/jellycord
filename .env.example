# Jellycord Server Configuration (Development/Local)
# Use godotenv.Overload() to override these in dev.

# Server Address
JELLYCORD_ADDR=:8080

# Redis Connection URL
JELLYCORD_REDIS_URL=redis://127.0.0.1:6379/0

# JWT Signing Secret (Change this in production!)
JELLYCORD_JWT_SECRET=dev-secret-change-me

# Admin Key for protected administrative routes
JELLYCORD_ADMIN_KEY=dev-admin-key-change-me

# Environment (development/production)
JELLYCORD_ENV=development

# Optional: Initial admin account bootstrap (only creates if doesn't exist)
JELLYCORD_BOOTSTRAP_ADMIN_USERNAME=admin
JELLYCORD_BOOTSTRAP_ADMIN_PASSWORD=password123
