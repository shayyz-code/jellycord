## JellyCord server (docker)
JELLYCORD_ADDR=:8080
JELLYCORD_REDIS_URL=redis://redis:6379/0

## Secrets (CHANGE THESE)
JELLYCORD_JWT_SECRET=change-me-long-random
JELLYCORD_ADMIN_KEY=change-me-admin-key

## Optional admin bootstrap on server startup
JELLYCORD_BOOTSTRAP_ADMIN_USERNAME=admin
JELLYCORD_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
