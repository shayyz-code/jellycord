## Deployment settings (used by scripts/push-deploy.sh)

# VPS public IP
JELLYCORD_VPS_IP=your.vps.ip.here

# User to SSH into the VPS
JELLYCORD_VPS_USER=root

# Bind/publish server port on the VPS
JELLYCORD_BIND_IP=0.0.0.0
JELLYCORD_HOST_PORT=8080

# Postgres settings
POSTGRES_USER=postgres
POSTGRES_DB=jellycord

# Repo install location on VPS
APP_DIR=/opt/jellycord
