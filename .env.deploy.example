## Deployment settings (used by docker-compose.prod.yml + scripts/vps-deploy.sh)
#
# VPS public IP (used for printing instructions)
JELLYCORD_VPS_IP=your-vps-public-ip
# User to SSH into the VPS
JELLYCORD_VPS_USER=your-vps-user
#
# Bind/publish server port on the VPS
JELLYCORD_BIND_IP=127.0.0.1
JELLYCORD_HOST_PORT=8080
#
# Repo install location / source
APP_DIR=/opt/jellycord

